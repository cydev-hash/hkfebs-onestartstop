#!/bin/bash
#==============================================================================
#  EBS System Manager
#
#  A unified command to start, stop, and check Oracle EBS services.
#
#  Install:  sudo cp ebs /usr/local/bin/ebs && sudo chmod +x /usr/local/bin/ebs
#  Usage:    ebs start [--skip-db]
#            ebs stop  [--skip-db]
#            ebs check [--skip-db]
#==============================================================================

set -o pipefail

#──────────────────────────────────────────────────────────────────────────────
# CONFIGURATION  (modify these values as needed)
#──────────────────────────────────────────────────────────────────────────────
DB_HOST="10.101.14.21"
DB_SSH_USER="opc"
DB_SSH_KEY="/home/opc/.ssh/ebs_db_key" # SSH key for DB server
DB_ORACLE_USER="oracle"
DB_SCRIPTS_DIR="/u01/app/oracle/product/19.0.0.0/dbhome_1/appsutil/scripts/UAT_ebsdbuat01"

APP_USER="applmgr"
EBS_ENV_FILE="/apps/ebs/fs1/EBSapps/EBSapps.env"

APPS_USERNAME="apps"
APPS_PASSWORD="apps"
WEBLOGIC_PASSWORD="welcome1"

CLEANUP_WAIT_SECS=300                # 5 minutes wait before force-killing

#──────────────────────────────────────────────────────────────────────────────
# DISPLAY HELPERS
#──────────────────────────────────────────────────────────────────────────────
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
BLUE='\033[0;34m'; CYAN='\033[0;36m'; MAGENTA='\033[0;35m'
BOLD='\033[1m'; DIM='\033[2m'; NC='\033[0m'

print_banner()  { echo ""; echo -e "${BOLD}${BLUE}╔══════════════════════════════════════════════════════════════════╗${NC}"; echo -e "${BOLD}${BLUE}║${NC}  ${BOLD}$1${NC}"; echo -e "${BOLD}${BLUE}╚══════════════════════════════════════════════════════════════════╝${NC}"; echo ""; }
print_header()  { echo ""; echo -e "${BOLD}${MAGENTA}── $1 ──${NC}"; echo ""; }
print_step()    { echo -e "${CYAN}[$(date '+%H:%M:%S')]${NC} ${BOLD}▶${NC} $1"; }
print_substep() { echo -e "${DIM}[$(date '+%H:%M:%S')]${NC}   $1"; }
print_success() { echo -e "${GREEN}[$(date '+%H:%M:%S')]${NC} ${GREEN}✔ $1${NC} ${DIM}($2)${NC}"; }
print_error()   { echo -e "${RED}[$(date '+%H:%M:%S')]${NC} ${RED}✘ $1${NC}"; }
print_warning() { echo -e "${YELLOW}[$(date '+%H:%M:%S')]${NC} ${YELLOW}⚠ $1${NC}"; }
print_info()    { echo -e "${DIM}[$(date '+%H:%M:%S')]${NC}   ${DIM}$1${NC}"; }

format_duration() {
    local s=$1
    if ((s >= 3600)); then printf "%dh %dm %ds" $((s/3600)) $((s%3600/60)) $((s%60))
    elif ((s >= 60)); then printf "%dm %ds" $((s/60)) $((s%60))
    else printf "%ds" $s; fi
}

# SSH options
SSH_OPTS="-o StrictHostKeyChecking=no -o ConnectTimeout=10 -o BatchMode=yes"
[[ -n "$DB_SSH_KEY" ]] && SSH_OPTS="$SSH_OPTS -i $DB_SSH_KEY"

# Step tracking
declare -a STEP_NAMES=()
declare -a STEP_DURATIONS=()
declare -a STEP_STATUSES=()
record_step() { STEP_NAMES+=("$1"); STEP_DURATIONS+=("$2"); STEP_STATUSES+=("$3"); }

print_summary_table() {
    local total_fmt=$1
    echo ""
    echo -e "  ${BOLD}Total Time:${NC}  ${total_fmt}"
    echo ""
    printf "  ${BOLD}%-35s %-15s %-20s${NC}\n" "Step" "Duration" "Status"
    printf "  %-35s %-15s %-20s\n" "───────────────────────────────────" "───────────────" "────────────────────"
    for i in "${!STEP_NAMES[@]}"; do
        local status="${STEP_STATUSES[$i]}"
        local color="$CYAN"
        case "$status" in SUCCESS) color="$GREEN" ;; SKIPPED) color="$YELLOW" ;; FAILED) color="$RED" ;; WARNING) color="$YELLOW" ;; esac
        printf "  %-35s %-15s ${color}%-20s${NC}\n" "${STEP_NAMES[$i]}" "${STEP_DURATIONS[$i]}" "${status}"
    done
    echo ""
}

test_db_ssh() {
    print_step "Testing SSH connectivity to DB server ${DB_HOST}..."
    if ssh ${SSH_OPTS} ${DB_SSH_USER}@${DB_HOST} "echo OK" &>/dev/null; then
        print_success "SSH connectivity confirmed" "OK"
        return 0
    else
        print_error "Cannot SSH to ${DB_SSH_USER}@${DB_HOST}"
        print_info "Set up SSH keys or use --skip-db"
        return 1
    fi
}

#==============================================================================
#  COMMAND: check
#==============================================================================
cmd_check() {
    local SKIP_DB=$1
    local UP=0 DOWN=0 WARN=0

    check_pass() { echo -e "  ${GREEN}✔ RUNNING${NC}  $1"; ((UP++)); }
    check_fail() { echo -e "  ${RED}✘ STOPPED${NC}  $1"; ((DOWN++)); }
    check_warn() { echo -e "  ${YELLOW}⚠ UNKNOWN${NC}  $1"; ((WARN++)); }

    echo ""
    echo -e "${BOLD}${CYAN}════════════════════════════════════════════════════════════════${NC}"
    echo -e "${BOLD}  EBS System Status Check  —  $(date '+%Y-%m-%d %H:%M:%S %Z')${NC}"
    echo -e "${BOLD}${CYAN}════════════════════════════════════════════════════════════════${NC}"

    # --- Database ---
    echo ""
    echo -e "${BOLD}  Database Server (${DB_HOST})${NC}"
    echo -e "  ${DIM}────────────────────────────────────────${NC}"

    if [[ "$SKIP_DB" == "false" ]]; then
        if ssh ${SSH_OPTS} ${DB_SSH_USER}@${DB_HOST} "echo OK" &>/dev/null; then
            if ssh ${SSH_OPTS} ${DB_SSH_USER}@${DB_HOST} "ps -ef | grep ora_pmon | grep -v grep" &>/dev/null; then
                local DB_NAME=$(ssh ${SSH_OPTS} ${DB_SSH_USER}@${DB_HOST} "ps -ef | grep ora_pmon | grep -v grep" 2>/dev/null | awk '{print $NF}' | sed 's/ora_pmon_//')
                check_pass "Oracle Database (${DB_NAME})"
            else
                check_fail "Oracle Database (ora_pmon)"
            fi
            local LSNR_INFO=$(ssh ${SSH_OPTS} ${DB_SSH_USER}@${DB_HOST} "ps -ef | grep tnslsnr | grep -v grep" 2>/dev/null | awk '{print $9}')
            if [[ -n "$LSNR_INFO" ]]; then
                check_pass "DB Listener (${LSNR_INFO})"
            else
                check_warn "DB Listener (may be Grid Infrastructure managed)"
            fi
        else
            check_warn "Cannot reach DB server via SSH"
            check_warn "DB Listener status unknown"
        fi
    else
        echo -e "  ${YELLOW}⚠ SKIPPED${NC}  Database checks skipped (--skip-db)"
    fi

    # --- Application ---
    echo ""
    echo -e "${BOLD}  Application Server ($(hostname))${NC}"
    echo -e "  ${DIM}────────────────────────────────────────${NC}"

    if ps -ef | grep -q "[w]eblogic.Server" 2>/dev/null; then check_pass "WebLogic Server"; else check_fail "WebLogic Server"; fi
    if ps -ef | grep -q "[h]ttpd" 2>/dev/null; then check_pass "Oracle HTTP Server (OHS)"; else check_fail "Oracle HTTP Server (OHS)"; fi
    if ps -ef | grep -q "[N]odeManager" 2>/dev/null; then check_pass "Node Manager"; else check_fail "Node Manager"; fi
    if ps -ef | grep -q "[F]NDLIBR" 2>/dev/null; then check_pass "Concurrent Manager (FNDLIBR)"; else check_fail "Concurrent Manager (FNDLIBR)"; fi
    if ps -ef | grep -q "[f]orms_server\|[d]_frd" 2>/dev/null; then check_pass "Forms Server"; else check_fail "Forms Server"; fi
    if ps -ef | grep -q "[o]afm_server" 2>/dev/null; then check_pass "OAFM Server"; else check_fail "OAFM Server"; fi
    if ps -ef | grep -q "[o]acore_server" 2>/dev/null; then check_pass "OACore Server"; else check_fail "OACore Server"; fi
    if ps -ef | grep -q "[t]nslsnr.*APPS_" 2>/dev/null; then check_pass "Apps Listener"; else check_fail "Apps Listener"; fi
    if ps -ef | grep -q "[o]pmn" 2>/dev/null; then check_pass "OPMN"; else check_fail "OPMN"; fi

    local APP_PROC_COUNT=$(ps -u ${APP_USER} -o pid= 2>/dev/null | wc -l)

    echo ""
    echo -e "${BOLD}${CYAN}════════════════════════════════════════════════════════════════${NC}"
    if ((DOWN == 0 && UP > 0)); then
        echo -e "  ${BOLD}${GREEN}Status: EBS SYSTEM IS RUNNING${NC}"
    elif ((UP == 0)); then
        echo -e "  ${BOLD}${RED}Status: EBS SYSTEM IS STOPPED${NC}"
    else
        echo -e "  ${BOLD}${YELLOW}Status: EBS SYSTEM IS PARTIALLY RUNNING${NC}"
    fi
    echo -e "  ${GREEN}${UP} running${NC}  |  ${RED}${DOWN} stopped${NC}  |  ${YELLOW}${WARN} unknown${NC}  |  ${DIM}${APP_PROC_COUNT} applmgr processes${NC}"
    echo -e "${BOLD}${CYAN}════════════════════════════════════════════════════════════════${NC}"
    echo ""
}

#==============================================================================
#  COMMAND: start
#==============================================================================
cmd_start() {
    local SKIP_DB=$1
    local SCRIPT_START_TIME=$(date +%s)

    print_banner "EBS SYSTEM STARTUP"
    echo -e "  ${BOLD}Date:${NC}        $(date '+%Y-%m-%d %H:%M:%S %Z')"
    echo -e "  ${BOLD}App Server:${NC}  $(hostname)"
    echo -e "  ${BOLD}DB Server:${NC}   ${DB_HOST}"
    echo -e "  ${BOLD}Skip DB:${NC}     ${SKIP_DB}"
    echo ""

    if [[ "$SKIP_DB" == "false" ]]; then
        test_db_ssh || exit 1
    fi
    echo -e "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

    # --- Start Database ---
    if [[ "$SKIP_DB" == "false" ]]; then
        print_header "STEP 1/3: Start Oracle Container Database"
        local STEP_START=$(date +%s)

        # Check if DB is already running
        if ssh ${SSH_OPTS} ${DB_SSH_USER}@${DB_HOST} "ps -ef | grep ora_pmon | grep -v grep" &>/dev/null; then
            print_success "Database is already running" "skipped"
            record_step "Start Database" "skipped" "ALREADY RUNNING"
        else
            print_step "Starting the container database on ${DB_HOST}..."
            local TMP_LOG=$(mktemp /tmp/ebs_db_start_XXXXXX.log)
            ssh ${SSH_OPTS} ${DB_SSH_USER}@${DB_HOST} \
                "sudo su - ${DB_ORACLE_USER} -c 'cd ${DB_SCRIPTS_DIR} && ./adcdbctl.sh start'" 2>&1 | \
                tee "${TMP_LOG}" | while IFS= read -r line; do
                case "$line" in
                    *"Starting the container database"*)  print_substep "$line" ;;
                    *"ORACLE instance started"*)          print_substep "$line" ;;
                    *"Database mounted"*)                 print_substep "$line" ;;
                    *"Database opened"*)                  print_substep "$line" ;;
                    *"Total System Global Area"*)         print_substep "$line" ;;
                    *"adcdbctl.sh: exiting"*)             print_substep "$line" ;;
                esac
            done
            local DUR_FMT=$(format_duration $(( $(date +%s) - STEP_START )))
            if grep -q "exiting with status 0" "${TMP_LOG}" 2>/dev/null; then
                print_success "Database startup complete" "${DUR_FMT}"
                record_step "Start Database" "$DUR_FMT" "SUCCESS"
            else
                print_error "Database startup failed"
                record_step "Start Database" "$DUR_FMT" "FAILED"
                rm -f "${TMP_LOG}"; exit 1
            fi
            rm -f "${TMP_LOG}"
        fi
    else
        print_header "STEP 1/3: Start Database (SKIPPED)"
        print_warning "Database startup skipped (--skip-db)"
        record_step "Start Database" "skipped" "SKIPPED"
    fi

    # --- Start EBS App ---
    print_header "STEP 2/3: Start EBS Application Services"
    local STEP_START=$(date +%s)
    print_step "Starting all EBS application services as ${APP_USER}..."
    print_info "This step may take 15-30 minutes. Key status updates shown below..."

    local TMP_LOG=$(mktemp /tmp/ebs_app_start_XXXXXX.log)
    local TMP_CREDS=$(mktemp /tmp/ebs_creds_XXXXXX)
    printf '%s\n' "${APPS_USERNAME}" "${APPS_PASSWORD}" "${WEBLOGIC_PASSWORD}" > "${TMP_CREDS}"
    chmod 644 "${TMP_CREDS}"

    sudo -u ${APP_USER} bash -c "source ${EBS_ENV_FILE} run 2>/dev/null; adstrtal.sh -nopromptmsg < ${TMP_CREDS}" 2>&1 | \
        tee "${TMP_LOG}" | while IFS= read -r line; do
        case "$line" in
            *"Starting Fulfillment"*)            print_substep "Starting Fulfillment Server..." ;;
            *"Starting Oracle Process"*)         print_substep "Starting OPMN..." ;;
            *"Starting OPMN managed"*)           print_substep "Starting Oracle HTTP Server (OHS)..." ;;
            *"Starting the Node Manager"*)       print_substep "Starting Node Manager..." ;;
            *"Checking for FNDFS"*|*"Starting listener process APPS"*)
                                                 print_substep "Starting Apps Listener..." ;;
            *"Starting concurrent manager"*)     print_substep "Starting Concurrent Manager..." ;;
            *"Starting WLS Admin"*)              print_substep "Starting WebLogic Admin Server..." ;;
            *"Starting forms_server"*)           print_substep "Starting Forms Server..." ;;
            *"Starting oafm_server"*)            print_substep "Starting OAFM Server..." ;;
            *"Starting oacore_server"*)          print_substep "Starting OACore Server..." ;;
            *"All enabled services"*)            print_substep "$line" ;;
        esac
    done
    local DUR_FMT=$(format_duration $(( $(date +%s) - STEP_START )))
    if grep -q "Exiting with status 0" "${TMP_LOG}" 2>/dev/null; then
        print_success "EBS Application services startup complete" "${DUR_FMT}"
        record_step "Start EBS App Services" "$DUR_FMT" "SUCCESS"
    else
        print_error "EBS Application services startup may have failed"
        record_step "Start EBS App Services" "$DUR_FMT" "FAILED"
        print_info "Check log: /apps/ebs/fs1/inst/apps/UAT_ebsuat01/logs/appl/admin/log/adstrtal.log"
    fi
    rm -f "${TMP_LOG}" "${TMP_CREDS}"

    # --- Verification ---
    print_header "STEP 3/3: Post-Startup Verification"
    local STEP_START=$(date +%s)
    local VERIFY_PASS=0 VERIFY_FAIL=0
    print_step "Verifying EBS system status..."

    if [[ "$SKIP_DB" == "false" ]]; then
        print_substep "Checking database processes on ${DB_HOST}..."
        if ssh ${SSH_OPTS} ${DB_SSH_USER}@${DB_HOST} "ps -ef | grep ora_pmon | grep -v grep" &>/dev/null; then
            print_success "Database (ora_pmon) is running" "OK"; ((VERIFY_PASS++))
        else
            print_error "Database (ora_pmon) is NOT running"; ((VERIFY_FAIL++))
        fi
        if ssh ${SSH_OPTS} ${DB_SSH_USER}@${DB_HOST} "ps -ef | grep tnslsnr | grep -v grep" &>/dev/null; then
            print_success "DB Listener (tnslsnr) is running" "OK"; ((VERIFY_PASS++))
        else
            print_warning "DB Listener (tnslsnr) not detected (may be Grid Infrastructure managed)"
        fi
    fi

    print_substep "Checking application processes on $(hostname)..."
    if ps -ef | grep -q "[w]eblogic.Server" 2>/dev/null; then print_success "WebLogic Server is running" "OK"; ((VERIFY_PASS++)); else print_error "WebLogic Server is NOT running"; ((VERIFY_FAIL++)); fi
    if ps -ef | grep -q "[h]ttpd" 2>/dev/null; then print_success "Oracle HTTP Server (OHS) is running" "OK"; ((VERIFY_PASS++)); else print_error "Oracle HTTP Server is NOT running"; ((VERIFY_FAIL++)); fi
    if ps -ef | grep -q "[F]NDLIBR" 2>/dev/null; then print_success "Concurrent Manager (FNDLIBR) is running" "OK"; ((VERIFY_PASS++)); else print_warning "Concurrent Manager not detected (may still be starting)"; fi
    if ps -ef | grep -q "[N]odeManager" 2>/dev/null; then print_success "Node Manager is running" "OK"; ((VERIFY_PASS++)); else print_error "Node Manager is NOT running"; ((VERIFY_FAIL++)); fi
    if ps -ef | grep -q "[f]orms_server\|[f]rmbld" 2>/dev/null; then print_success "Forms Server is running" "OK"; ((VERIFY_PASS++)); else print_warning "Forms Server not detected (may still be starting)"; fi
    if ps -ef | grep -q "[t]nslsnr.*APPS_" 2>/dev/null; then print_success "Apps Listener is running" "OK"; ((VERIFY_PASS++)); else print_warning "Apps Listener not detected"; fi

    local DUR_FMT=$(format_duration $(( $(date +%s) - STEP_START )))
    record_step "Verification" "$DUR_FMT" "${VERIFY_PASS} passed, ${VERIFY_FAIL} failed"

    # --- Summary ---
    local TOTAL_FMT=$(format_duration $(( $(date +%s) - SCRIPT_START_TIME )))
    echo ""
    echo -e "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    if ((VERIFY_FAIL == 0)); then
        echo -e "  ${BOLD}${GREEN}╔══════════════════════════════════════════════════════════╗${NC}"
        echo -e "  ${BOLD}${GREEN}║     ✔  EBS SYSTEM STARTUP COMPLETED SUCCESSFULLY       ║${NC}"
        echo -e "  ${BOLD}${GREEN}╚══════════════════════════════════════════════════════════╝${NC}"
    else
        echo -e "  ${BOLD}${YELLOW}╔══════════════════════════════════════════════════════════╗${NC}"
        echo -e "  ${BOLD}${YELLOW}║     ⚠  EBS SYSTEM STARTUP COMPLETED WITH WARNINGS      ║${NC}"
        echo -e "  ${BOLD}${YELLOW}╚══════════════════════════════════════════════════════════╝${NC}"
    fi
    print_summary_table "$TOTAL_FMT"
    echo -e "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    [[ $VERIFY_FAIL -gt 0 ]] && exit 1 || exit 0
}

#==============================================================================
#  COMMAND: stop
#==============================================================================
cmd_stop() {
    local SKIP_DB=$1
    local SCRIPT_START_TIME=$(date +%s)

    print_banner "EBS SYSTEM SHUTDOWN"
    echo -e "  ${BOLD}Date:${NC}        $(date '+%Y-%m-%d %H:%M:%S %Z')"
    echo -e "  ${BOLD}App Server:${NC}  $(hostname)"
    echo -e "  ${BOLD}DB Server:${NC}   ${DB_HOST}"
    echo -e "  ${BOLD}Skip DB:${NC}     ${SKIP_DB}"
    echo ""

    if [[ "$SKIP_DB" == "false" ]]; then
        test_db_ssh || exit 1
    fi
    echo -e "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"

    # --- Stop EBS App ---
    print_header "STEP 1/4: Stop EBS Application Services"
    local STEP_START=$(date +%s)
    print_step "Stopping all EBS application services as ${APP_USER}..."
    print_info "This step may take 10-20 minutes. Key status updates shown below..."

    local TMP_LOG=$(mktemp /tmp/ebs_app_stop_XXXXXX.log)
    local TMP_CREDS=$(mktemp /tmp/ebs_creds_XXXXXX)
    printf '%s\n' "${APPS_USERNAME}" "${APPS_PASSWORD}" "${WEBLOGIC_PASSWORD}" > "${TMP_CREDS}"
    chmod 644 "${TMP_CREDS}"

    sudo -u ${APP_USER} bash -c "source ${EBS_ENV_FILE} run 2>/dev/null; adstpall.sh -nopromptmsg < ${TMP_CREDS}" 2>&1 | \
        tee "${TMP_LOG}" | while IFS= read -r line; do
        case "$line" in
            *"Stopping OPMN managed"*|*"Stopping Oracle HTTP"*)  print_substep "Stopping Oracle HTTP Server (OHS)..." ;;
            *"Shutting down concurrent"*)        print_substep "Stopping Concurrent Manager..." ;;
            *"Shutting down Fulfillment"*)       print_substep "Stopping Fulfillment Server..." ;;
            *"Stopping Oracle Process"*)         print_substep "Stopping OPMN..." ;;
            *"Stopping oacore_server"*)          print_substep "Stopping OACore Server..." ;;
            *"Stopping oafm_server"*)            print_substep "Stopping OAFM Server..." ;;
            *"Stopping forms_server"*)           print_substep "Stopping Forms Server..." ;;
            *"Shutting down listener"*)          print_substep "Stopping Apps Listener..." ;;
            *"Stopping WLS Admin"*)              print_substep "Stopping WebLogic Admin Server..." ;;
            *"Stopping.*Node"*|*"adnodemgrctl"*stop*) print_substep "Stopping Node Manager..." ;;
            *"All enabled services"*stopped*)    print_substep "$line" ;;
        esac
    done
    local DUR_FMT=$(format_duration $(( $(date +%s) - STEP_START )))
    if grep -q "Exiting with status 0" "${TMP_LOG}" 2>/dev/null; then
        print_success "EBS Application services stopped" "${DUR_FMT}"
        record_step "Stop EBS App Services" "$DUR_FMT" "SUCCESS"
    else
        print_warning "EBS Application services stop may have had issues"
        record_step "Stop EBS App Services" "$DUR_FMT" "WARNING"
        print_info "Check log: /apps/ebs/fs1/inst/apps/UAT_ebsuat01/logs/appl/admin/log/adstpall.log"
    fi
    rm -f "${TMP_LOG}" "${TMP_CREDS}"

    # --- Cleanup ---
    print_header "STEP 2/4: Cleanup Remaining Processes"
    local STEP_START=$(date +%s)
    print_step "Checking for remaining ${APP_USER} processes..."

    local REMAINING=$(ps -u ${APP_USER} -o pid= 2>/dev/null | wc -l)
    if ((REMAINING == 0)); then
        local DUR_FMT=$(format_duration $(( $(date +%s) - STEP_START )))
        print_success "No remaining ${APP_USER} processes found" "${DUR_FMT}"
        record_step "Cleanup Processes" "$DUR_FMT" "SUCCESS"
    else
        print_warning "${REMAINING} ${APP_USER} processes still running"
        print_step "Waiting up to 5 minutes for graceful termination..."
        local WAIT_START=$(date +%s)
        while true; do
            REMAINING=$(ps -u ${APP_USER} -o pid= 2>/dev/null | wc -l)
            local ELAPSED=$(( $(date +%s) - WAIT_START ))
            if ((REMAINING == 0)); then
                print_success "All ${APP_USER} processes have terminated" "$(format_duration $ELAPSED)"; break
            fi
            if ((ELAPSED >= CLEANUP_WAIT_SECS)); then
                print_warning "${REMAINING} processes still running after 5 minutes"
                print_step "Force killing remaining ${APP_USER} processes..."
                sudo pkill -9 -u ${APP_USER} 2>/dev/null || true
                sleep 3
                REMAINING=$(ps -u ${APP_USER} -o pid= 2>/dev/null | wc -l)
                if ((REMAINING == 0)); then print_success "All remaining processes force-killed" "OK"
                else print_warning "${REMAINING} processes could not be killed"; fi
                break
            fi
            print_info "Waiting... ${REMAINING} processes remaining ($(format_duration $((CLEANUP_WAIT_SECS - ELAPSED))) left)"
            sleep 30
        done
        local DUR_FMT=$(format_duration $(( $(date +%s) - STEP_START )))
        record_step "Cleanup Processes" "$DUR_FMT" "SUCCESS"
    fi

    # --- Stop Database ---
    if [[ "$SKIP_DB" == "false" ]]; then
        print_header "STEP 3/4: Stop Oracle Container Database"
        local STEP_START=$(date +%s)

        # Check if DB is already stopped
        if ! ssh ${SSH_OPTS} ${DB_SSH_USER}@${DB_HOST} "ps -ef | grep ora_pmon | grep -v grep" &>/dev/null; then
            print_success "Database is already stopped" "skipped"
            record_step "Stop Database" "skipped" "ALREADY STOPPED"
        else
            print_step "Stopping the container database on ${DB_HOST}..."
            local TMP_LOG=$(mktemp /tmp/ebs_db_stop_XXXXXX.log)
            ssh ${SSH_OPTS} ${DB_SSH_USER}@${DB_HOST} \
                "sudo su - ${DB_ORACLE_USER} -c 'cd ${DB_SCRIPTS_DIR} && ./adcdbctl.sh stop'" 2>&1 | \
                tee "${TMP_LOG}" | while IFS= read -r line; do
                case "$line" in
                    *"Shutting down container database"*)  print_substep "$line" ;;
                    *"Database closed"*)                   print_substep "$line" ;;
                    *"Database dismounted"*)               print_substep "$line" ;;
                    *"ORACLE instance shut down"*)         print_substep "$line" ;;
                    *"adcdbctl.sh: exiting"*)              print_substep "$line" ;;
                esac
            done
            local DUR_FMT=$(format_duration $(( $(date +%s) - STEP_START )))
            if grep -q "exiting with status 0" "${TMP_LOG}" 2>/dev/null; then
                print_success "Database shutdown complete" "${DUR_FMT}"
                record_step "Stop Database" "$DUR_FMT" "SUCCESS"
            else
                print_error "Database shutdown may have failed"
                record_step "Stop Database" "$DUR_FMT" "FAILED"
            fi
            rm -f "${TMP_LOG}"
        fi
    else
        print_header "STEP 3/4: Stop Database (SKIPPED)"
        print_warning "Database shutdown skipped (--skip-db)"
        record_step "Stop Database" "skipped" "SKIPPED"
    fi

    # --- Verification ---
    print_header "STEP 4/4: Post-Shutdown Verification"
    local STEP_START=$(date +%s)
    local VERIFY_PASS=0 VERIFY_FAIL=0
    print_step "Verifying EBS system is fully stopped..."

    if [[ "$SKIP_DB" == "false" ]]; then
        print_substep "Checking database processes on ${DB_HOST}..."
        if ssh ${SSH_OPTS} ${DB_SSH_USER}@${DB_HOST} "ps -ef | grep ora_pmon | grep -v grep" &>/dev/null; then
            print_error "Database (ora_pmon) is still running!"; ((VERIFY_FAIL++))
        else
            print_success "Database (ora_pmon) is stopped" "OK"; ((VERIFY_PASS++))
        fi
    fi

    print_substep "Checking application processes on $(hostname)..."
    local APP_PROCS=$(ps -u ${APP_USER} -o pid= 2>/dev/null | wc -l)
    if ((APP_PROCS == 0)); then print_success "No ${APP_USER} processes running" "OK"; ((VERIFY_PASS++)); else print_warning "${APP_PROCS} ${APP_USER} processes still running"; ((VERIFY_FAIL++)); fi
    if ps -ef | grep -q "[w]eblogic.Server" 2>/dev/null; then print_error "WebLogic Server is still running!"; ((VERIFY_FAIL++)); else print_success "WebLogic Server is stopped" "OK"; ((VERIFY_PASS++)); fi
    if ps -ef | grep -q "[h]ttpd" 2>/dev/null; then print_error "HTTP Server is still running!"; ((VERIFY_FAIL++)); else print_success "HTTP Server is stopped" "OK"; ((VERIFY_PASS++)); fi
    if ps -ef | grep -q "[N]odeManager" 2>/dev/null; then print_error "Node Manager is still running!"; ((VERIFY_FAIL++)); else print_success "Node Manager is stopped" "OK"; ((VERIFY_PASS++)); fi

    local DUR_FMT=$(format_duration $(( $(date +%s) - STEP_START )))
    record_step "Verification" "$DUR_FMT" "${VERIFY_PASS} passed, ${VERIFY_FAIL} failed"

    # --- Summary ---
    local TOTAL_FMT=$(format_duration $(( $(date +%s) - SCRIPT_START_TIME )))
    echo ""
    echo -e "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    if ((VERIFY_FAIL == 0)); then
        echo -e "  ${BOLD}${GREEN}╔══════════════════════════════════════════════════════════╗${NC}"
        echo -e "  ${BOLD}${GREEN}║     ✔  EBS SYSTEM SHUTDOWN COMPLETED SUCCESSFULLY      ║${NC}"
        echo -e "  ${BOLD}${GREEN}╚══════════════════════════════════════════════════════════╝${NC}"
    else
        echo -e "  ${BOLD}${YELLOW}╔══════════════════════════════════════════════════════════╗${NC}"
        echo -e "  ${BOLD}${YELLOW}║     ⚠  EBS SYSTEM SHUTDOWN COMPLETED WITH WARNINGS     ║${NC}"
        echo -e "  ${BOLD}${YELLOW}╚══════════════════════════════════════════════════════════╝${NC}"
    fi
    print_summary_table "$TOTAL_FMT"
    echo -e "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    [[ $VERIFY_FAIL -gt 0 ]] && exit 1 || exit 0
}

#==============================================================================
#  MAIN — Parse command and options
#==============================================================================
show_usage() {
    echo ""
    echo -e "${BOLD}EBS System Manager${NC}"
    echo ""
    echo -e "  ${BOLD}Usage:${NC}  ebs <command> [options]"
    echo ""
    echo -e "  ${BOLD}Commands:${NC}"
    echo -e "    ${GREEN}start${NC}    Start the EBS system (DB + Application)"
    echo -e "    ${RED}stop${NC}     Stop the EBS system (Application + DB)"
    echo -e "    ${CYAN}check${NC}    Check current status of all EBS services"
    echo ""
    echo -e "  ${BOLD}Options:${NC}"
    echo -e "    --skip-db    Skip database operations (app services only)"
    echo -e "    --help, -h   Show this help message"
    echo ""
    echo -e "  ${BOLD}Examples:${NC}"
    echo -e "    ebs check              # Check if EBS is running"
    echo -e "    ebs start              # Full startup (DB + App)"
    echo -e "    ebs start --skip-db    # Start app services only"
    echo -e "    ebs stop               # Full shutdown (App + DB)"
    echo -e "    ebs stop --skip-db     # Stop app services only"
    echo ""
}

# Parse command
CMD="${1:-}"
shift 2>/dev/null || true

# Parse options
SKIP_DB=false
for arg in "$@"; do
    case "$arg" in
        --skip-db) SKIP_DB=true ;;
        --help|-h) show_usage; exit 0 ;;
    esac
done

case "$CMD" in
    start)  cmd_start "$SKIP_DB" ;;
    stop)   cmd_stop "$SKIP_DB" ;;
    check)  cmd_check "$SKIP_DB" ;;
    --help|-h|help) show_usage ;;
    *)
        if [[ -n "$CMD" ]]; then
            echo -e "${RED}Unknown command: ${CMD}${NC}" >&2
        fi
        show_usage
        exit 1
        ;;
esac
